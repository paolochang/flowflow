<Window
    x:Class="FlowFlow.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:FlowFlow.Models"
    Title="FlowFlow">

    <Grid x:Name="ShellRoot" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="20,16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="2">
                    <TextBlock Text="FlowFlow" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding RootPath}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <Button Grid.Column="1" Command="{Binding CaptureFullScreenCommand}" Padding="14,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE722;" FontSize="14" />
                        <TextBlock Text="Full screen" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="2" Click="CaptureRegion_Click" Padding="14,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                        <TextBlock Text="Region" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Border Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Projects" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject, Mode=TwoWay}" DisplayMemberPath="Name" HorizontalAlignment="Stretch" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox PlaceholderText="project-name" Text="{Binding NewProjectName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Command="{Binding CreateProjectCommand}">
                                <FontIcon Glyph="&#xE710;" FontSize="14" />
                            </Button>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Tasks" FontWeight="SemiBold" />
                        <ListView ItemsSource="{Binding Tasks}" SelectedItem="{Binding SelectedTask, Mode=TwoWay}" DisplayMemberPath="Name" Height="220" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox PlaceholderText="task-name" Text="{Binding NewTaskName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Command="{Binding CreateTaskCommand}">
                                <FontIcon Glyph="&#xE710;" FontSize="14" />
                            </Button>
                        </Grid>
                    </StackPanel>

                    <InfoBar IsOpen="True" Severity="Informational" IsClosable="False" Title="Hotkeys" Message="Ctrl+Shift+1 captures the full desktop. Ctrl+Shift+2 starts region capture." />
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Padding="16" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="220" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>

                    <ListView ItemsSource="{Binding Screenshots}" SelectedItem="{Binding SelectedScreenshot, Mode=TwoWay}">
                        <ListView.Header>
                            <TextBlock Text="Screenshots" FontWeight="SemiBold" Margin="0,0,0,8" />
                        </ListView.Header>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ScreenshotInfo">
                                <Grid Padding="0,8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{x:Bind FileName}" FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Bind RelativePath}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{x:Bind Kind}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Grid.Column="1" Spacing="10">
                        <TextBlock Text="Metadata" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding ScreenshotKinds}" SelectedItem="{Binding SelectedScreenshot.Kind, Mode=TwoWay}" HorizontalAlignment="Stretch" />
                        <TextBox Header="Memo" Text="{Binding SelectedScreenshot.Memo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" Height="150" />
                        <Button Command="{Binding SaveScreenshotMetadataCommand}" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74E;" FontSize="14" />
                                <TextBlock Text="Save metadata" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <TextBox Grid.Row="1" Header="Task notes" Text="{Binding TaskNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" />
            </Grid>

            <Border Grid.Column="2" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,0,0,0">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding RegeneratePromptCommand}">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        </Button>
                        <Button Command="{Binding CopyResumePromptCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                <TextBlock Text="Copy resume prompt" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <TextBox Grid.Row="1" Text="{Binding ResumePrompt, Mode=TwoWay}" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="16,8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Border>
    </Grid>
</Window>
